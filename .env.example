### Database (Neon, Frankfurt or Dublin) ###
# Pooled connection (used at runtime).
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
# Direct (non-pooled) connection — used by Prisma migrate.
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

### Authentication (Auth.js v5) ###
# Sole allowed sign-in address. Magic links to any other address are rejected.
OWNER_EMAIL=""
# Random 32+ char string. Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Public URL of the deployed web app. Auth.js v5 prefers AUTH_URL.
AUTH_URL="http://localhost:3000"
# Compatibility fallback only — read if AUTH_URL is unset.
NEXTAUTH_URL="http://localhost:3000"

### LLM (Anthropic Messages API) ###
ANTHROPIC_API_KEY=""
# Model used for relevance + drafting. Worker fails loudly at startup if
# the configured model is rejected by the API.
ANTHROPIC_MODEL="claude-sonnet-4-5"
# In-app assistant model. The assistant runs in the web app only.
ASSISTANT_MODEL="claude-opus-4-7"
# Plain Messages API only for relevance/drafting. The assistant uses tool
# use and Anthropic's web_search tool — narrowly scoped, web only.

### Transactional email (Resend) ###
# Used ONLY for magic-link sign-in and generic owner notifications. Resend
# does NOT provide EU data residency — never send client content via Resend.
RESEND_API_KEY=""
RESEND_FROM="BD updates <updates@example.dev>"

### Optional: embeddings provider for exemplar retrieval ###
# Leave blank to use the local TF-IDF fallback
OPENAI_API_KEY=""

### Polling cadence (cron expressions, all in UTC) ###
# CMA Atom: every 10 min during 0700-2000 UK, every 30 min outside.
# (Approximate in UTC. Tighten further via /settings if needed.)
CRON_CMA_ATOM_BUSINESS="*/10 6-19 * * *"
CRON_CMA_ATOM_OFFHOURS="*/30 0-5,20-23 * * *"
CRON_EC_PRESS_BUSINESS="*/10 6-19 * * *"
CRON_EC_PRESS_OFFHOURS="*/30 0-5,20-23 * * *"
CRON_EC_CASES_BUSINESS="*/15 6-19 * * *"
CRON_EC_CASES_OFFHOURS="0 0-5,20-23 * * *"
CRON_DGCOMP_DAILY="0 6 * * *"

### Misc ###
# Used for batching email notifications (in seconds)
NOTIFICATION_BATCH_WINDOW_SECONDS="300"
# Defaults to "default-workspace" — single-tenant for now
WORKSPACE_ID="default-workspace"
# Worker exposes a tiny health/admin endpoint on this port
WORKER_HEALTH_PORT="8080"
# Web app -> worker admin endpoint. e.g. https://<worker>.fly.dev
WORKER_ADMIN_URL=""
# Shared secret for /admin/* requests
WORKER_ADMIN_TOKEN=""

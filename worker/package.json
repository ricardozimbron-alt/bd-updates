{
  "name": "@bdu/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "poll-once": "tsx src/scripts/poll-once.ts",
    "process-pending": "node --env-file=../.env --import tsx src/scripts/process-pending.ts",
    "seed-events": "node --env-file=../.env --import tsx src/scripts/seed-events.ts",
    "smoke-llm": "node --env-file=../.env --import tsx src/scripts/smoke-llm.ts",
    "regen-one": "node --env-file=../.env --import tsx src/scripts/regen-one.ts",
    "complete-orphans": "node --env-file=../.env --import tsx src/scripts/complete-orphans.ts",
    "dev-signin": "node --env-file=../.env --import tsx src/scripts/dev-signin.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@bdu/lib": "workspace:*",
    "@prisma/client": "^6.1.0",
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^4.5.1",
    "node-cron": "^3.0.3",
    "playwright-core": "^1.49.0",
    "resend": "^4.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
